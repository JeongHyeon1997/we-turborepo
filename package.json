{
  "name": "we-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "latest"
  },
  "workspaces": [
    "apps/app/*",
    "apps/web/*",
    "packages/*"
  ],
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  },
  "resolutions": {
    "@types/react": "~19.1.3"
  }
}

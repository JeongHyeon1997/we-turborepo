{
  "name": "we-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "prettier": "latest",
    "turbo": "latest"
  },
  "workspaces": [
    "apps/app/*",
    "apps/web/*",
    "apps/api",
    "packages/*"
  ],
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "@types/react": "~19.1.3"
  },
  "dependencies": {
    "react-router-dom": "^7.13.2"
  }
}
